# Per-environment secrets & config for provision-env.sh.
# Copy this to env.dev / env.staging / env.prod (these are gitignored) and fill in.
# Values map 1:1 to the app's runtime env vars (see .env.example at repo root).

# App
JWT_SECRET=                 # long random string; DIFFERENT per environment
ADMIN_EMAIL=                # bootstrap admin (works even if dbo.Users is down)
ADMIN_PASSWORD=
IMPORT_CRYPT_KEY=           # key used to encrypt stored SFTP feed secrets

# SQL Server (external — 74.117.224.152).
# NOTE: for dev/staging, point at a NON-PROD database/schema so test writes
# never touch live data. Only prod should use the live DB.
SQLSERVER_HOST=74.117.224.152
SQLSERVER_DB=iRx
SQLSERVER_USER=claudeservices
SQLSERVER_PASSWORD=
SQLSERVER_PORT=1433

# Optional: pin a specific image tag instead of :latest, e.g.
# IMAGE=acrtpcrm.azurecr.io/tpcrm:49fa5f3
